{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "frontend": {
      "root": ".",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main:app"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "service": "backend"
    },
    {
      "src": "/(.*)",
      "service": "frontend"
    }
  ]
}
