# Frontend environment variables
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws

# Optional: client-side Gemini integration
NEXT_PUBLIC_GEMINI_API_KEY=

# Local proxy target for the Next.js dev server
NEXT_PUBLIC_API_PROXY_TARGET=http://127.0.0.1:8000

# For Vercel production deployments, set these to your deployed backend URL instead:
# NEXT_PUBLIC_API_URL=https://your-backend.example.com/api/v1
# NEXT_PUBLIC_WS_URL=wss://your-backend.example.com/ws

# Copy backend/.env.example to backend/.env for backend configuration
