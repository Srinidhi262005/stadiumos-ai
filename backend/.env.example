PROJECT_NAME=StadiumOS AI Backend
ENVIRONMENT=development
API_V1_STR=/api/v1

# Use a production-grade Postgres URL for deployment
DATABASE_URL=sqlite:///./stadiumos.db

SECRET_KEY=change-me-in-production

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

GEMINI_API_KEY=change-me

SUPABASE_URL=https://example.supabase.co
SUPABASE_ANON_KEY=replace-me

# Comma-separated list of allowed origins for CORS and redirects
# Example: https://your-app.vercel.app,https://your-api-domain.com
ALLOWED_HOSTS=["*"]
